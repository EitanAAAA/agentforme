<Window x:Class="SMTAgent.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SMTAgent.Desktop.Controls"
        xmlns:converters="clr-namespace:SMTAgent.Desktop.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SMT Agent"
        MinHeight="780"
        MinWidth="1180"
        Height="860"
        Width="1380"
        Background="#070B12"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:StatusBrushConverter x:Key="StatusBrushConverter" />
        <converters:DataStatusBrushConverter x:Key="DataStatusBrushConverter" />
        <converters:SignalBrushConverter x:Key="SignalBrushConverter" />
        <converters:SignalTitleConverter x:Key="SignalTitleConverter" />

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#0D1421" />
            <Setter Property="BorderBrush" Value="#1C2A3E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EEF4FF" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8997B0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="HelperTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#70819D" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,8" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F4F8FF" />
            <Setter Property="Background" Value="#172235" />
            <Setter Property="BorderBrush" Value="#263A54" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinWidth" Value="74" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#22334C" />
                    <Setter Property="BorderBrush" Value="#3B5578" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#101827" />
            <Setter Property="Foreground" Value="#F4F8FF" />
            <Setter Property="BorderBrush" Value="#263A54" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="MinWidth" Value="104" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DCE6F7" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PanelBorderStyle}"
                Padding="18,14"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="SMT Agent"
                               Foreground="#F6FAFF"
                               FontSize="27"
                               FontWeight="Bold"
                               Margin="0,0,18,0" />
                    <Border Background="#111B2B"
                            BorderBrush="{Binding Status, Converter={StaticResource StatusBrushConverter}}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="10,5"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8"
                                     Height="8"
                                     Fill="{Binding Status, Converter={StaticResource StatusBrushConverter}}"
                                     Margin="0,0,7,0" />
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="#F5F9FF"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Background="#111B2B"
                            BorderBrush="#263A54"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="10,5"
                            Margin="0,0,10,0">
                        <TextBlock Text="{Binding DataProviderText, StringFormat=Provider: {0}}"
                                   Foreground="#C9D7EA"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Border Background="#111B2B"
                            BorderBrush="{Binding DataStatus, Converter={StaticResource DataStatusBrushConverter}}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="10,5"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8"
                                     Height="8"
                                     Fill="{Binding DataStatus, Converter={StaticResource DataStatusBrushConverter}}"
                                     Margin="0,0,7,0" />
                            <TextBlock Text="{Binding DataStatusText}"
                                       Foreground="#F5F9FF"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{Binding LastUpdatedText}"
                               Style="{StaticResource MutedTextStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Timeframe"
                               Style="{StaticResource MutedTextStyle}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <Border Background="#111B2B"
                            BorderBrush="#263A54"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,7"
                            Margin="0,0,12,0">
                        <TextBlock Text="15m"
                                   Foreground="#F4F8FF"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Button Content="Start"
                            Command="{Binding StartCommand}"
                            Background="#1A6E58"
                            BorderBrush="#32D39A"
                            Margin="0,0,8,0" />
                    <Button Content="Pause"
                            Command="{Binding PauseCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="Stop"
                            Command="{Binding StopCommand}"
                            Background="#37202B"
                            BorderBrush="#E75673" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource PanelBorderStyle}"
                    Margin="0,0,14,7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="ES Chart" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="Swings and SMT markers"
                                   Style="{StaticResource MutedTextStyle}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <controls:MarketChart Grid.Row="1"
                                          Symbol="ES"
                                          Candles="{Binding EsCandles}"
                                          SwingPoints="{Binding EsSwings}"
                                          Signals="{Binding Signals}" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Style="{StaticResource PanelBorderStyle}"
                    Margin="0,7,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="NQ Chart" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="Swings and SMT markers"
                                   Style="{StaticResource MutedTextStyle}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <controls:MarketChart Grid.Row="1"
                                          Symbol="NQ"
                                          Candles="{Binding NqCandles}"
                                          SwingPoints="{Binding NqSwings}"
                                          Signals="{Binding Signals}" />
                </Grid>
            </Border>

            <Grid Grid.Column="1" Grid.RowSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2.1*" />
                    <RowDefinition Height="1.5*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource PanelBorderStyle}"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="SMT Events"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,10" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       Style="{StaticResource MutedTextStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Signals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#111B2B"
                                                BorderBrush="#243650"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12"
                                                Margin="0,0,0,10">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Type, Converter={StaticResource SignalTitleConverter}}"
                                                               Foreground="{Binding Type, Converter={StaticResource SignalBrushConverter}}"
                                                               FontSize="15"
                                                               FontWeight="Bold" />
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Text="{Binding Time, StringFormat={}{0:HH:mm}}"
                                                               Foreground="#8997B0"
                                                               FontSize="12" />
                                                </DockPanel>
                                                <Grid Margin="0,10,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Leader symbol" Style="{StaticResource MutedTextStyle}" />
                                                        <TextBlock Text="{Binding LeaderSymbol}"
                                                                   Foreground="#F4F8FF"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="Failed confirmation" Style="{StaticResource MutedTextStyle}" />
                                                        <TextBlock Text="{Binding FailedSymbol}"
                                                                   Foreground="#F4F8FF"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock Text="{Binding DetectionMode}"
                                                           Foreground="#AFC4E3"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,8" />
                                                <UniformGrid Columns="2" Margin="0,0,0,8">
                                                    <StackPanel Margin="0,0,8,0">
                                                        <TextBlock Text="ES prev / current" Style="{StaticResource MutedTextStyle}" />
                                                        <TextBlock Foreground="#DCE6F7" FontSize="12" FontWeight="SemiBold">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0:0.00} / {1:0.00}">
                                                                    <Binding Path="EsPreviousSwingValue" />
                                                                    <Binding Path="EsCurrentValue" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock Text="NQ prev / current" Style="{StaticResource MutedTextStyle}" />
                                                        <TextBlock Foreground="#DCE6F7" FontSize="12" FontWeight="SemiBold">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0:0.00} / {1:0.00}">
                                                                    <Binding Path="NqPreviousSwingValue" />
                                                                    <Binding Path="NqCurrentValue" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </UniformGrid>
                                                <TextBlock Text="{Binding Reason}"
                                                           Foreground="#C7D2E5"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           LineHeight="18" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource PanelBorderStyle}"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="SMT Event Logs"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,10" />
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Logs}"
                                 Background="#09101B"
                                 BorderBrush="#1C2A3E"
                                 Foreground="#B8C7DD"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 Padding="8"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource PanelBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Settings"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="{Binding SwingStrength, StringFormat=Swing strength: {0}}"
                                   Foreground="#DCE6F7"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Controls how many candles on each side must confirm a swing high or low."
                                   Style="{StaticResource HelperTextStyle}" />
                        <Slider Minimum="1"
                                Maximum="6"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding SwingStrength, Mode=TwoWay}"
                                Margin="0,4,0,12" />

                        <TextBlock Text="Detection mode"
                                   Foreground="#DCE6F7"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="Wick uses High/Low; Close Confirmation requires the candle close to break."
                                   Style="{StaticResource HelperTextStyle}" />
                        <ComboBox ItemsSource="{Binding DetectionModes}"
                                  SelectedItem="{Binding SelectedDetectionMode}"
                                  Margin="0,0,0,12" />

                        <TextBlock Text="{Binding RefreshRateSeconds, StringFormat=Refresh rate: {0} sec}"
                                   Foreground="#DCE6F7"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="How often Yahoo Finance 15-minute candles are refreshed."
                                   Style="{StaticResource HelperTextStyle}" />
                        <Slider Minimum="15"
                                Maximum="300"
                                TickFrequency="15"
                                IsSnapToTickEnabled="True"
                                Value="{Binding RefreshRateSeconds, Mode=TwoWay}"
                                Margin="0,4,0,12" />

                        <TextBlock Text="{Binding AlertCooldownMinutes, StringFormat=Alert cooldown: {0} min}"
                                   Foreground="#DCE6F7"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Suppresses repeat alerts for the same leader, failed symbol, type, and mode."
                                   Style="{StaticResource HelperTextStyle}" />
                        <Slider Minimum="0"
                                Maximum="10"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding AlertCooldownMinutes, Mode=TwoWay}"
                                Margin="0,4,0,8" />

                        <CheckBox Content="Show Bullish SMT"
                                  IsChecked="{Binding ShowBullishSmt}" />
                        <TextBlock Text="Shows low-break divergence events in the feed and charts."
                                   Style="{StaticResource HelperTextStyle}" />
                        <CheckBox Content="Show Bearish SMT"
                                  IsChecked="{Binding ShowBearishSmt}" />
                        <TextBlock Text="Shows high-break divergence events in the feed and charts."
                                   Style="{StaticResource HelperTextStyle}" />

                        <TextBlock Text="Data Provider"
                                   Foreground="#DCE6F7"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,6" />
                        <TextBlock Text="Yahoo Finance is live delayed data; Mock is retained for fallback and demo mode."
                                   Style="{StaticResource HelperTextStyle}" />
                        <ComboBox ItemsSource="{Binding DataProviders}"
                                  SelectedItem="{Binding SelectedDataProvider}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
