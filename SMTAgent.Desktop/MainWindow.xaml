<Window x:Class="SMTAgent.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SMTAgent.Desktop.Controls"
        xmlns:converters="clr-namespace:SMTAgent.Desktop.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SMT Agent"
        MinHeight="780"
        MinWidth="1180"
        Height="900"
        Width="1440"
        Background="#05070C"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StatusBrushConverter x:Key="StatusBrushConverter" />
        <converters:DataStatusBrushConverter x:Key="DataStatusBrushConverter" />
        <converters:SignalBrushConverter x:Key="SignalBrushConverter" />
        <converters:SignalTitleConverter x:Key="SignalTitleConverter" />

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#090D14" />
            <Setter Property="BorderBrush" Value="#1A2332" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F3F6FA" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8190A5" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="HelperTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#66758C" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,10" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F3F6FA" />
            <Setter Property="Background" Value="#111824" />
            <Setter Property="BorderBrush" Value="#263247" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="13,7" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#182335" />
                    <Setter Property="BorderBrush" Value="#3A4C69" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#101722" />
            <Setter Property="Foreground" Value="#F3F6FA" />
            <Setter Property="BorderBrush" Value="#263247" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="MinWidth" Value="160" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#DCE5F3" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#080C13"
                    BorderBrush="#172033"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="SMT Agent"
                                   Foreground="#F5F7FA"
                                   FontSize="21"
                                   FontWeight="Bold"
                                   Margin="0,0,16,0" />
                        <Border Background="#101722"
                                BorderBrush="#263247"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="9,5"
                                Margin="0,0,8,0">
                            <TextBlock Text="15m locked"
                                       Foreground="#DCE5F3"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#2A2110"
                                BorderBrush="#F5B743"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="9,5"
                                Margin="0,0,8,0">
                            <TextBlock Text="DELAYED DATA - live updating view"
                                       Foreground="#FFD88A"
                                       FontSize="12"
                                       FontWeight="Bold" />
                        </Border>
                        <Border Background="#101722"
                                BorderBrush="{Binding DataStatus, Converter={StaticResource DataStatusBrushConverter}}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="9,5"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7"
                                         Height="7"
                                         Fill="{Binding DataStatus, Converter={StaticResource DataStatusBrushConverter}}"
                                         Margin="0,0,7,0" />
                                <TextBlock Text="{Binding DataStatusText}"
                                           Foreground="#F5F7FA"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="{Binding DataProviderText, StringFormat=Provider: {0}}"
                                   Style="{StaticResource MutedTextStyle}"
                                   VerticalAlignment="Center"
                                   Margin="2,0,12,0" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#AAB7CB"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="520"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="{Binding LastUpdatedText}"
                               Style="{StaticResource MutedTextStyle}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Margin="0,0,14,0" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Start"
                                Command="{Binding StartCommand}"
                                Background="#116149"
                                BorderBrush="#2CCF96"
                                Margin="0,0,8,0" />
                        <Button Content="Pause"
                                Command="{Binding PauseCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Stop"
                                Command="{Binding StopCommand}"
                                Background="#2A1720"
                                BorderBrush="#D94F68"
                                Margin="0,0,8,0" />
                        <Button Content="Settings"
                                Command="{Binding OpenSettingsCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,12,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="0,0,0,6">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEsYahooFetchPulseActive}" Value="True">
                                        <Setter Property="BorderBrush" Value="#F5D547" />
                                        <Setter Property="BorderThickness" Value="2" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="ES"
                                               Style="{StaticResource SectionTitleStyle}"
                                               Margin="0,0,10,0" />
                                    <TextBlock Text="Yahoo delayed 15m candles"
                                               Style="{StaticResource MutedTextStyle}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Zoom +"
                                            Command="{Binding ChartZoomInCommand}"
                                            CommandParameter="ES"
                                            MinWidth="58"
                                            Padding="8,4"
                                            Margin="0,0,6,0" />
                                    <Button Content="Zoom -"
                                            Command="{Binding ChartZoomOutCommand}"
                                            CommandParameter="ES"
                                            MinWidth="58"
                                            Padding="8,4"
                                            Margin="0,0,6,0" />
                                    <Button Content="Reset"
                                            Command="{Binding ChartResetViewCommand}"
                                            CommandParameter="ES"
                                            MinWidth="54"
                                            Padding="8,4"
                                            Margin="0,0,6,0" />
                                    <Button Content="Fit"
                                            Command="{Binding ChartFitDataCommand}"
                                            CommandParameter="ES"
                                            MinWidth="42"
                                            Padding="8,4"
                                            Margin="0,0,6,0" />
                                    <Button Content="Go To Latest"
                                            Command="{Binding ChartGoToLatestCommand}"
                                            CommandParameter="ES"
                                            MinWidth="82"
                                            Padding="8,4"
                                            Margin="0,0,8,0" />
                                    <CheckBox Content="Auto"
                                              IsChecked="{Binding EsAutoScrollToLatest, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0" />
                                    <Button Content="{Binding SyncChartViewsText}"
                                            Command="{Binding ToggleSyncChartsCommand}"
                                            MinWidth="72"
                                            Padding="8,4" />
                                </StackPanel>
                            </Grid>
                            <controls:MarketChart Grid.Row="1"
                                                  Symbol="ES"
                                                  Candles="{Binding EsCandles}"
                                                  SwingPoints="{Binding EsSwings}"
                                                  Signals="{Binding Signals}"
                                                  ViewStartIndex="{Binding EsViewStartIndex, Mode=TwoWay}"
                                                  VisibleCandleCount="{Binding EsVisibleCandleCount, Mode=TwoWay}"
                                                  AutoScrollToLatest="{Binding EsAutoScrollToLatest, Mode=TwoWay}"
                                                  CrosshairTime="{Binding EsCrosshairTime, Mode=TwoWay}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,6,0,0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource PanelBorderStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNqYahooFetchPulseActive}" Value="True">
                                        <Setter Property="BorderBrush" Value="#F5D547" />
                                        <Setter Property="BorderThickness" Value="2" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="NQ"
                                               Style="{StaticResource SectionTitleStyle}"
                                               Margin="0,0,10,0" />
                                    <TextBlock Text="Yahoo delayed 15m candles"
                                               Style="{StaticResource MutedTextStyle}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Zoom +"
                                            Command="{Binding ChartZoomInCommand}"
                                            CommandParameter="NQ"
                                            MinWidth="58"
                                            Padding="8,4"
                                            Margin="0,0,6,0" />
                                    <Button Content="Zoom -"
                                            Command="{Binding ChartZoomOutCommand}"
                                            CommandParameter="NQ"
                                            MinWidth="58"
                                            Padding="8,4"
                                            Margin="0,0,6,0" />
                                    <Button Content="Reset"
                                            Command="{Binding ChartResetViewCommand}"
                                            CommandParameter="NQ"
                                            MinWidth="54"
                                            Padding="8,4"
                                            Margin="0,0,6,0" />
                                    <Button Content="Fit"
                                            Command="{Binding ChartFitDataCommand}"
                                            CommandParameter="NQ"
                                            MinWidth="42"
                                            Padding="8,4"
                                            Margin="0,0,6,0" />
                                    <Button Content="Go To Latest"
                                            Command="{Binding ChartGoToLatestCommand}"
                                            CommandParameter="NQ"
                                            MinWidth="82"
                                            Padding="8,4"
                                            Margin="0,0,8,0" />
                                    <CheckBox Content="Auto"
                                              IsChecked="{Binding NqAutoScrollToLatest, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0" />
                                    <Button Content="{Binding SyncChartViewsText}"
                                            Command="{Binding ToggleSyncChartsCommand}"
                                            MinWidth="72"
                                            Padding="8,4" />
                                </StackPanel>
                            </Grid>
                            <controls:MarketChart Grid.Row="1"
                                                  Symbol="NQ"
                                                  Candles="{Binding NqCandles}"
                                                  SwingPoints="{Binding NqSwings}"
                                                  Signals="{Binding Signals}"
                                                  ViewStartIndex="{Binding NqViewStartIndex, Mode=TwoWay}"
                                                  VisibleCandleCount="{Binding NqVisibleCandleCount, Mode=TwoWay}"
                                                  AutoScrollToLatest="{Binding NqAutoScrollToLatest, Mode=TwoWay}"
                                                  CrosshairTime="{Binding NqCrosshairTime, Mode=TwoWay}" />
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Column="1"
                        Style="{StaticResource PanelBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="SMT Events"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,0,5" />
                            <TextBlock Text="Analytics-only dashboard."
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Signals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#0F1621"
                                                BorderBrush="#202B3B"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="11"
                                                Margin="0,0,0,10">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Type, Converter={StaticResource SignalTitleConverter}}"
                                                               Foreground="{Binding Type, Converter={StaticResource SignalBrushConverter}}"
                                                               FontSize="14"
                                                               FontWeight="Bold" />
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Text="{Binding Time, StringFormat={}{0:HH:mm}}"
                                                               Foreground="#8190A5"
                                                               FontSize="12" />
                                                </DockPanel>

                                                <UniformGrid Columns="2" Margin="0,10,0,8">
                                                    <StackPanel Margin="0,0,8,0">
                                                        <TextBlock Text="Leader" Style="{StaticResource MutedTextStyle}" />
                                                        <TextBlock Text="{Binding LeaderSymbol}"
                                                                   Foreground="#F3F6FA"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold" />
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock Text="Failed" Style="{StaticResource MutedTextStyle}" />
                                                        <TextBlock Text="{Binding FailedSymbol}"
                                                                   Foreground="#F3F6FA"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </UniformGrid>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="{Binding Status}"
                                                               Foreground="#FFD88A"
                                                               FontSize="12"
                                                               FontWeight="Bold" />
                                                    <TextBlock Text="  |  "
                                                               Foreground="#8190A5"
                                                               FontSize="12"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding DetectionMode}"
                                                               Foreground="#A8BCE0"
                                                               FontSize="12"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="  |  Timeframe: 15m"
                                                               Foreground="#8190A5"
                                                               FontSize="12"
                                                               FontWeight="SemiBold" />
                                                </StackPanel>

                                                <UniformGrid Columns="2" Margin="0,0,0,8">
                                                    <StackPanel Margin="0,0,8,0">
                                                        <TextBlock Text="ES prev / current" Style="{StaticResource MutedTextStyle}" />
                                                        <TextBlock Foreground="#DCE5F3" FontSize="12" FontWeight="SemiBold">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0:0.00} / {1:0.00}">
                                                                    <Binding Path="EsPreviousSwingValue" />
                                                                    <Binding Path="EsCurrentValue" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock Text="NQ prev / current" Style="{StaticResource MutedTextStyle}" />
                                                        <TextBlock Foreground="#DCE5F3" FontSize="12" FontWeight="SemiBold">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0:0.00} / {1:0.00}">
                                                                    <Binding Path="NqPreviousSwingValue" />
                                                                    <Binding Path="NqCurrentValue" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </UniformGrid>

                                                <UniformGrid Columns="2" Margin="0,0,0,8">
                                                    <StackPanel Margin="0,0,8,0">
                                                        <TextBlock Text="Leader prev / current" Style="{StaticResource MutedTextStyle}" />
                                                        <TextBlock Foreground="#F3F6FA" FontSize="12" FontWeight="SemiBold">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0}: {1:0.00} / {2:0.00}">
                                                                    <Binding Path="LeaderSymbol" />
                                                                    <Binding Path="LeaderPreviousSwingValue" />
                                                                    <Binding Path="LeaderCurrentValue" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock Text="Failed prev / current" Style="{StaticResource MutedTextStyle}" />
                                                        <TextBlock Foreground="#F3F6FA" FontSize="12" FontWeight="SemiBold">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0}: {1:0.00} / {2:0.00}">
                                                                    <Binding Path="FailedSymbol" />
                                                                    <Binding Path="FailedPreviousSwingValue" />
                                                                    <Binding Path="FailedCurrentValue" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </UniformGrid>

                                                <TextBlock Text="{Binding Tolerance, StringFormat=Tolerance: {0:0.##}}"
                                                           Foreground="#A8BCE0"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,8" />

                                                <TextBlock Text="{Binding Reason}"
                                                           Foreground="#C7D2E5"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           LineHeight="18" />
                                                <TextBlock Text="{Binding WorkflowState}"
                                                           Foreground="#FFD88A"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Background="#99000000"
              Panel.ZIndex="10"
              Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="390"
                    HorizontalAlignment="Right"
                    Background="#090D14"
                    BorderBrush="#263247"
                    BorderThickness="1,0,0,0"
                    Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,16">
                            <TextBlock Text="Settings"
                                       Style="{StaticResource SectionTitleStyle}"
                                       FontSize="18" />
                            <Button DockPanel.Dock="Right"
                                    Content="Close"
                                    Command="{Binding CloseSettingsCommand}"
                                    MinWidth="64" />
                        </DockPanel>

                        <TextBlock Text="Data Provider"
                                   Foreground="#DCE5F3"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="Yahoo Delayed uses ES=F and NQ=F from Yahoo Finance. Manual Demo is explicit non-market demo mode."
                                   Style="{StaticResource HelperTextStyle}" />
                        <ComboBox ItemsSource="{Binding DataProviders}"
                                  SelectedItem="{Binding SelectedDataProvider}"
                                  Margin="0,0,0,16" />

                        <TextBlock Text="Timeframe: 15m"
                                   Foreground="#DCE5F3"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="The dashboard is locked to synchronized 15-minute candles."
                                   Style="{StaticResource HelperTextStyle}" />

                        <CheckBox Content="Sync ES/NQ chart view"
                                  IsChecked="{Binding SyncChartViews}" />
                        <TextBlock Text="Keeps zoom, pan, latest position, and crosshair time aligned between ES and NQ."
                                   Style="{StaticResource HelperTextStyle}" />

                        <TextBlock Text="{Binding RefreshRateSeconds, StringFormat=Refresh rate: {0} sec}"
                                   Foreground="#DCE5F3"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="How often Yahoo Finance candles are fetched and the latest candle is refreshed."
                                   Style="{StaticResource HelperTextStyle}" />
                        <Slider Minimum="15"
                                Maximum="300"
                                TickFrequency="15"
                                IsSnapToTickEnabled="True"
                                Value="{Binding RefreshRateSeconds, Mode=TwoWay}"
                                Margin="0,4,0,16" />

                        <TextBlock Text="{Binding SwingStrength, StringFormat=Swing strength: {0}}"
                                   Foreground="#DCE5F3"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Candles on each side needed to confirm a swing high or low."
                                   Style="{StaticResource HelperTextStyle}" />
                        <Slider Minimum="1"
                                Maximum="6"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding SwingStrength, Mode=TwoWay}"
                                Margin="0,4,0,16" />

                        <TextBlock Text="Detection mode"
                                   Foreground="#DCE5F3"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="Wick uses high/low. Close confirmation requires the candle close to break."
                                   Style="{StaticResource HelperTextStyle}" />
                        <ComboBox ItemsSource="{Binding DetectionModes}"
                                  SelectedItem="{Binding SelectedDetectionMode}"
                                  Margin="0,0,0,16" />

                        <TextBlock Text="{Binding AlertCooldownMinutes, StringFormat=Alert cooldown: {0} min}"
                                   Foreground="#DCE5F3"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Suppress repeat alerts for the same type, leader, failed symbol, and mode."
                                   Style="{StaticResource HelperTextStyle}" />
                        <Slider Minimum="0"
                                Maximum="10"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding AlertCooldownMinutes, Mode=TwoWay}"
                                Margin="0,4,0,16" />

                        <TextBlock Text="{Binding AlertCooldownCandles, StringFormat=Alert cooldown candles: {0}}"
                                   Foreground="#DCE5F3"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Suppresses another alert from the same direction and swing zone for this many candles."
                                   Style="{StaticResource HelperTextStyle}" />
                        <Slider Minimum="0"
                                Maximum="50"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding AlertCooldownCandles, Mode=TwoWay}"
                                Margin="0,4,0,16" />

                        <TextBlock Text="{Binding TickTolerance, StringFormat=Tick tolerance: {0} tick(s)}"
                                   Foreground="#DCE5F3"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="A break must cross beyond the previous swing by this many ticks."
                                   Style="{StaticResource HelperTextStyle}" />
                        <Slider Minimum="0"
                                Maximum="10"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding TickTolerance, Mode=TwoWay}"
                                Margin="0,4,0,16" />

                        <CheckBox Content="Show Bullish SMT"
                                  IsChecked="{Binding ShowBullishSmt}" />
                        <TextBlock Text="Displays low-break divergence events and their low-to-low lines."
                                   Style="{StaticResource HelperTextStyle}" />
                        <CheckBox Content="Show Bearish SMT"
                                  IsChecked="{Binding ShowBearishSmt}" />
                        <TextBlock Text="Displays high-break divergence events and their high-to-high lines."
                                   Style="{StaticResource HelperTextStyle}" />
                        <CheckBox Content="Sound alerts"
                                  IsChecked="{Binding SoundAlerts}" />
                        <TextBlock Text="Plays a local sound when a new visible SMT event appears."
                                   Style="{StaticResource HelperTextStyle}" />
                        <CheckBox Content="Desktop notifications"
                                  IsChecked="{Binding DesktopNotifications}" />
                        <TextBlock Text="Promotes the newest SMT event in the dashboard status area."
                                   Style="{StaticResource HelperTextStyle}" />

                        <Border Background="#101722"
                                BorderBrush="#263247"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="Yahoo delayed feed"
                                           Foreground="#F3F6FA"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Endpoint: query1.finance.yahoo.com/v8/finance/chart"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="0,0,0,5" />
                                <TextBlock Text="Symbols: ES=F and NQ=F. Data is delayed market data."
                                           Style="{StaticResource HelperTextStyle}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
