<Window x:Class="SMTAgent.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SMTAgent.Desktop.Controls"
        xmlns:converters="clr-namespace:SMTAgent.Desktop.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SMT Agent"
        MinHeight="780"
        MinWidth="1260"
        Height="900"
        Width="1540"
        Background="#F7F9FD"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StatusBrushConverter x:Key="StatusBrushConverter" />
        <converters:DataStatusBrushConverter x:Key="DataStatusBrushConverter" />
        <converters:SignalBrushConverter x:Key="SignalBrushConverter" />
        <converters:SignalTitleConverter x:Key="SignalTitleConverter" />

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D9E0EA" />
            <Setter Property="Foreground" Value="#20242C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5FF" />
                    <Setter Property="BorderBrush" Value="#2F6BFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}" />

        <Style x:Key="EventCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F6F8FC" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#20242C" />
            <Setter Property="BorderBrush" Value="#D5DCE8" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="MinWidth" Value="150" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#252A33" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="HelperTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7B8494" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,2,0,10" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#141821" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ChartFrameStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#23262D" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style x:Key="QuoteBoxStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinWidth" Value="96" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="66" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="330" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="3"
                Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="#E2E7F0"
                BorderThickness="0,0,1,0">
            <Grid>
                <StackPanel VerticalAlignment="Top" Margin="8,8,8,0">
                    <Border Width="48" Height="48" Background="#F0F2F6" CornerRadius="8" Margin="0,0,0,12">
                        <TextBlock Text="+"
                                   Foreground="#242832"
                                   FontSize="32"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="/"
                               FontSize="32"
                               Foreground="#2A2E37"
                               HorizontalAlignment="Center"
                               Margin="0,2" />
                    <TextBlock Text="--"
                               FontSize="24"
                               Foreground="#2A2E37"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0" />
                    <TextBlock Text="S"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#2A2E37"
                               HorizontalAlignment="Center"
                               Margin="0,14,0,0" />
                    <TextBlock Text="T"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#2A2E37"
                               HorizontalAlignment="Center"
                               Margin="0,14,0,0" />
                    <TextBlock Text=":-)"
                               FontSize="18"
                               Foreground="#2A2E37"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0" />
                    <Rectangle Height="1" Fill="#E5E9F1" Margin="0,18" />
                    <TextBlock Text="+"
                               FontSize="26"
                               Foreground="#2A2E37"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="link"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"
                               Background="#242832"
                               Padding="8,10"
                               HorizontalAlignment="Center"
                               Margin="0,18,0,0" />
                </StackPanel>
                <TextBlock Text="del"
                           FontSize="13"
                           Foreground="#2A2E37"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,16" />
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Background="#FFFFFF"
                BorderBrush="#E2E7F0"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="SMT Agent"
                               Foreground="#111827"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,14,0" />
                    <Border Background="#F5F8FF"
                            BorderBrush="#2F6BFF"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="8,4"
                            Margin="0,0,8,0">
                        <TextBlock Text="{Binding TimeframeText}"
                                   Foreground="#2F6BFF"
                                   FontSize="12"
                                   FontWeight="Bold" />
                    </Border>
                    <ItemsControl ItemsSource="{Binding Timeframes}" Margin="0,0,8,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}"
                                        Command="{Binding DataContext.SelectTimeframeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Padding="8,4"
                                        Margin="0,0,4,0" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Background="#FFFFFF"
                            BorderBrush="{Binding DataStatus, Converter={StaticResource DataStatusBrushConverter}}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="9,4"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7"
                                     Height="7"
                                     Fill="{Binding DataStatus, Converter={StaticResource DataStatusBrushConverter}}"
                                     Margin="0,0,6,0" />
                            <TextBlock Text="{Binding DataStatusText}"
                                       Foreground="#1F2937"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{Binding DataProviderText}"
                               Style="{StaticResource MutedTextStyle}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Foreground="#4B5563"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           MaxWidth="620" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LastUpdatedText}"
                               Style="{StaticResource MutedTextStyle}"
                               VerticalAlignment="Center"
                               Margin="0,0,14,0" />
                    <Button Content="Start"
                            Command="{Binding StartCommand}"
                            Background="#FFFFFF"
                            BorderBrush="#16A085"
                            Foreground="#0F8F75"
                            Margin="0,0,6,0" />
                    <Button Content="Pause"
                            Command="{Binding PauseCommand}"
                            Margin="0,0,6,0" />
                    <Button Content="Stop"
                            Command="{Binding StopCommand}"
                            BorderBrush="#F23645"
                            Foreground="#F23645"
                            Margin="0,0,6,0" />
                    <Button Content="Settings"
                            Command="{Binding OpenSettingsCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Grid.Column="1"
              Background="#FFFFFF"
              Visibility="{Binding IsComparisonDashboardVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ChartFrameStyle}" Margin="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="104" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="#EEF4FF" Margin="0">
                        <StackPanel Margin="10,7,10,0">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="26" Height="26" Background="#0A84FF" CornerRadius="13" Margin="0,0,6,0">
                                    <TextBlock Text="100" Foreground="#FFFFFF" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Foreground="#111827"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <Binding Path="SelectedTimeframe" StringFormat="NASDAQ 100 E-mini Futures - {0} - CME" />
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Text="   ..." Foreground="#111827" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{Binding NqOhlcText}"
                                       Foreground="#F23645"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Margin="0,3,0,6" />
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource QuoteBoxStyle}" BorderBrush="#F23645" Margin="0,0,68,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding NqSellText}" Foreground="#F23645" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock Text="SELL" Foreground="#F23645" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource QuoteBoxStyle}" BorderBrush="#2F6BFF">
                                    <StackPanel>
                                        <TextBlock Text="{Binding NqBuyText}" Foreground="#2F6BFF" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock Text="BUY" Foreground="#2F6BFF" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <controls:MarketChart Grid.Row="1"
                                          Symbol="NQ"
                                          Candles="{Binding NqCandles}"
                                          SwingPoints="{Binding NqSwings}"
                                          Signals="{Binding Signals}"
                                          ViewStartIndex="{Binding NqViewStartIndex, Mode=TwoWay}"
                                          VisibleCandleCount="{Binding NqVisibleCandleCount, Mode=TwoWay}"
                                          AutoScrollToLatest="{Binding NqAutoScrollToLatest, Mode=TwoWay}"
                                          CrosshairTime="{Binding NqCrosshairTime, Mode=TwoWay}" />
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource ChartFrameStyle}" Margin="-1.5,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="104" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="#EEF4FF">
                        <StackPanel Margin="10,7,10,0">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="26" Height="26" Background="#D91F42" CornerRadius="13" Margin="0,0,6,0">
                                    <TextBlock Text="500" Foreground="#FFFFFF" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Foreground="#111827"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <Binding Path="SelectedTimeframe" StringFormat="S&amp;P 500 E-mini Futures - {0} - CME" />
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Text="   ..." Foreground="#111827" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="{Binding EsOhlcText}"
                                       Foreground="#F23645"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Margin="0,3,0,6" />
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource QuoteBoxStyle}" BorderBrush="#F23645" Margin="0,0,68,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding EsSellText}" Foreground="#F23645" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock Text="SELL" Foreground="#F23645" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource QuoteBoxStyle}" BorderBrush="#2F6BFF">
                                    <StackPanel>
                                        <TextBlock Text="{Binding EsBuyText}" Foreground="#2F6BFF" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock Text="BUY" Foreground="#2F6BFF" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <controls:MarketChart Grid.Row="1"
                                          Symbol="ES"
                                          Candles="{Binding EsCandles}"
                                          SwingPoints="{Binding EsSwings}"
                                          Signals="{Binding Signals}"
                                          ViewStartIndex="{Binding EsViewStartIndex, Mode=TwoWay}"
                                          VisibleCandleCount="{Binding EsVisibleCandleCount, Mode=TwoWay}"
                                          AutoScrollToLatest="{Binding EsAutoScrollToLatest, Mode=TwoWay}"
                                          CrosshairTime="{Binding EsCrosshairTime, Mode=TwoWay}" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1"
              Grid.Column="1"
              Background="#FFFFFF"
              Visibility="{Binding IsFocusedNqAnalysisOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="118" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#EEF4FF"
                    BorderBrush="#D9E0EA"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <ToggleButton Content="Show BOS"
                                      IsChecked="{Binding ShowBos}"
                                      Padding="9,5"
                                      Margin="0,0,6,0" />
                        <ToggleButton Content="Show FVG"
                                      IsChecked="{Binding ShowFvg}"
                                      Padding="9,5"
                                      Margin="0,0,6,0" />
                        <ToggleButton Content="Show IFVG"
                                      IsChecked="{Binding ShowIfvg}"
                                      Padding="9,5"
                                      Margin="0,0,6,0" />
                        <ToggleButton Content="Show 0.5 Box"
                                      IsChecked="{Binding ShowHalfBox}"
                                      Padding="9,5"
                                      Margin="0,0,6,0" />
                        <ToggleButton Content="Show SL/TP"
                                      IsChecked="{Binding ShowSlTp}"
                                      Padding="9,5"
                                      Margin="0,0,10,0" />
                        <Button Content="Back"
                                Command="{Binding CloseFocusedAnalysisCommand}"
                                Padding="12,5" />
                    </StackPanel>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="26" Height="26" Background="#0A84FF" CornerRadius="13" Margin="0,0,8,0">
                                <TextBlock Text="100" Foreground="#FFFFFF" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{Binding FocusedTitle}"
                                       Foreground="#111827"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Border Background="#FFF4CC"
                                    BorderBrush="#FACC15"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="8,3"
                                    Margin="10,0,0,0">
                                <TextBlock Text="visual training only"
                                           Foreground="#854D0E"
                                           FontSize="11"
                                           FontWeight="Bold" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding NqOhlcText}"
                                   Foreground="#F23645"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,5,0,3" />
                        <TextBlock Text="{Binding FocusedAnalysisSummary}"
                                   Foreground="#374151"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="720" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource ChartFrameStyle}">
                <controls:MarketChart Symbol="NQ"
                                      Candles="{Binding FocusedNqCandles}"
                                      FocusedAnnotations="{Binding FocusedNqAnnotations}"
                                      ViewStartIndex="{Binding NqViewStartIndex, Mode=TwoWay}"
                                      VisibleCandleCount="{Binding NqVisibleCandleCount, Mode=TwoWay}"
                                      AutoScrollToLatest="{Binding NqAutoScrollToLatest, Mode=TwoWay}"
                                      CrosshairTime="{Binding NqCrosshairTime, Mode=TwoWay}" />
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Grid.Column="2"
                Background="#FFFFFF"
                BorderBrush="#E2E7F0"
                BorderThickness="1,0,0,0">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="SMT Events"
                               Style="{StaticResource SectionTitleStyle}"
                               FontSize="18" />
                    <TextBlock Text="Analytics only. No broker or order execution."
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Signals}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource EventCardButtonStyle}"
                                        Command="{Binding DataContext.SelectSignalCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,0,10">
                                    <Border Background="#FFFFFF"
                                            BorderBrush="#DDE3EE"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="11">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock Text="{Binding SetupType, Converter={StaticResource SignalTitleConverter}}"
                                                           Foreground="{Binding Type, Converter={StaticResource SignalBrushConverter}}"
                                                           FontSize="14"
                                                           FontWeight="Bold" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding Time, StringFormat={}{0:HH:mm}}"
                                                           Foreground="#6B7280"
                                                           FontSize="12" />
                                            </DockPanel>
                                            <UniformGrid Columns="2" Margin="0,10,0,8">
                                                <StackPanel Margin="0,0,8,0">
                                                    <TextBlock Text="Leader" Style="{StaticResource MutedTextStyle}" />
                                                    <TextBlock Text="{Binding LeaderSymbol}" Foreground="#111827" FontSize="15" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <StackPanel>
                                                    <TextBlock Text="Failed" Style="{StaticResource MutedTextStyle}" />
                                                    <TextBlock Text="{Binding FailedSymbol}" Foreground="#111827" FontSize="15" FontWeight="SemiBold" />
                                                </StackPanel>
                                            </UniformGrid>
                                            <TextBlock Text="{Binding DetectionMode}"
                                                       Foreground="#2F6BFF"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,8" />
                                            <UniformGrid Columns="2" Margin="0,0,0,8">
                                                <StackPanel Margin="0,0,8,0">
                                                    <TextBlock Text="ES prev / current" Style="{StaticResource MutedTextStyle}" />
                                                    <TextBlock Foreground="#111827" FontSize="12" FontWeight="SemiBold">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0:0.00} / {1:0.00}">
                                                                <Binding Path="EsPreviousSwingValue" />
                                                                <Binding Path="EsCurrentValue" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel>
                                                    <TextBlock Text="NQ prev / current" Style="{StaticResource MutedTextStyle}" />
                                                    <TextBlock Foreground="#111827" FontSize="12" FontWeight="SemiBold">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0:0.00} / {1:0.00}">
                                                                <Binding Path="NqPreviousSwingValue" />
                                                                <Binding Path="NqCurrentValue" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </StackPanel>
                                            </UniformGrid>
                                            <TextBlock Text="{Binding Reason}"
                                                       Foreground="#374151"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       LineHeight="17" />
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Background="#FFFFFF"
                BorderBrush="#E2E7F0"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="1D" FontWeight="SemiBold" Margin="0,0,18,0" />
                    <TextBlock Text="5D" FontWeight="SemiBold" Margin="0,0,18,0" />
                    <TextBlock Text="1M" FontWeight="SemiBold" Margin="0,0,18,0" />
                    <TextBlock Text="3M" FontWeight="SemiBold" Margin="0,0,18,0" />
                    <TextBlock Text="6M" FontWeight="SemiBold" Margin="0,0,18,0" />
                    <TextBlock Text="YTD" FontWeight="SemiBold" Margin="0,0,18,0" />
                    <TextBlock Text="1Y" FontWeight="SemiBold" Margin="0,0,18,0" />
                    <TextBlock Text="All" FontWeight="SemiBold" Margin="0,0,18,0" />
                    <Button Content="{Binding SyncChartViewsText}"
                            Command="{Binding ToggleSyncChartsCommand}"
                            Padding="10,4" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Zoom +"
                            Command="{Binding ChartZoomInCommand}"
                            CommandParameter="ES"
                            Padding="9,4"
                            Margin="0,0,6,0" />
                    <Button Content="Zoom -"
                            Command="{Binding ChartZoomOutCommand}"
                            CommandParameter="ES"
                            Padding="9,4"
                            Margin="0,0,6,0" />
                    <Button Content="Go To Latest"
                            Command="{Binding ChartGoToLatestCommand}"
                            CommandParameter="ES"
                            Padding="9,4"
                            Margin="0,0,12,0" />
                    <TextBlock Text="ETH"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0" />
                    <TextBlock Text="B-ADJ"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.ColumnSpan="3"
              Grid.RowSpan="3"
              Background="#66FFFFFF"
              Panel.ZIndex="10"
              Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="390"
                    HorizontalAlignment="Right"
                    Background="#FFFFFF"
                    BorderBrush="#D9E0EA"
                    BorderThickness="1,0,0,0"
                    Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,16">
                            <TextBlock Text="Settings"
                                       Style="{StaticResource SectionTitleStyle}"
                                       FontSize="20" />
                            <Button DockPanel.Dock="Right"
                                    Content="Close"
                                    Command="{Binding CloseSettingsCommand}"
                                    MinWidth="64" />
                        </DockPanel>

                        <TextBlock Text="Data Provider" Foreground="#111827" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="Yahoo Delayed uses ES=F and NQ=F from Yahoo Finance. Manual Demo is explicit non-market demo mode."
                                   Style="{StaticResource HelperTextStyle}" />
                        <ComboBox ItemsSource="{Binding DataProviders}"
                                  SelectedItem="{Binding SelectedDataProvider}"
                                  Margin="0,0,0,16" />

                        <TextBlock Text="{Binding SelectedTimeframe, StringFormat={}Timeframe: {0}}" Foreground="#111827" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="Use the top bar to switch between 30s, 1m, 5m, and 15m views."
                                   Style="{StaticResource HelperTextStyle}" />

                        <CheckBox Content="Sync ES/NQ chart view" IsChecked="{Binding SyncChartViews}" />
                        <TextBlock Text="Optional. Leave off when you want ES and NQ zoom/pan to move independently."
                                   Style="{StaticResource HelperTextStyle}" />

                        <TextBlock Text="{Binding RefreshRateSeconds, StringFormat=Refresh rate: {0} sec}" Foreground="#111827" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="How often Yahoo Finance candles are fetched and the latest candle is refreshed."
                                   Style="{StaticResource HelperTextStyle}" />
                        <Slider Minimum="15" Maximum="300" TickFrequency="15" IsSnapToTickEnabled="True" Value="{Binding RefreshRateSeconds, Mode=TwoWay}" Margin="0,4,0,16" />

                        <TextBlock Text="{Binding SwingStrength, StringFormat=Swing strength: {0}}" Foreground="#111827" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="Candles on each side needed to confirm a swing high or low."
                                   Style="{StaticResource HelperTextStyle}" />
                        <Slider Minimum="1" Maximum="6" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding SwingStrength, Mode=TwoWay}" Margin="0,4,0,16" />

                        <TextBlock Text="Detection mode" Foreground="#111827" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="Wick uses high/low. Close confirmation requires the candle close to break."
                                   Style="{StaticResource HelperTextStyle}" />
                        <ComboBox ItemsSource="{Binding DetectionModes}"
                                  SelectedItem="{Binding SelectedDetectionMode}"
                                  Margin="0,0,0,16" />

                        <TextBlock Text="{Binding AlertCooldownMinutes, StringFormat=Alert cooldown: {0} min}" Foreground="#111827" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="Suppress repeat alerts for the same type, leader, failed symbol, and mode."
                                   Style="{StaticResource HelperTextStyle}" />
                        <Slider Minimum="0" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding AlertCooldownMinutes, Mode=TwoWay}" Margin="0,4,0,16" />

                        <TextBlock Text="{Binding AlertCooldownCandles, StringFormat=Alert cooldown candles: {0}}" Foreground="#111827" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="Suppresses another alert from the same direction and swing zone for this many candles."
                                   Style="{StaticResource HelperTextStyle}" />
                        <Slider Minimum="0" Maximum="50" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding AlertCooldownCandles, Mode=TwoWay}" Margin="0,4,0,16" />

                        <TextBlock Text="{Binding TickTolerance, StringFormat=Tick tolerance: {0} tick(s)}" Foreground="#111827" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="A break must cross beyond the previous swing by this many ticks."
                                   Style="{StaticResource HelperTextStyle}" />
                        <Slider Minimum="0" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding TickTolerance, Mode=TwoWay}" Margin="0,4,0,16" />

                        <CheckBox Content="Show Bullish SMT" IsChecked="{Binding ShowBullishSmt}" />
                        <TextBlock Text="Displays low-break divergence events and their low-to-low lines."
                                   Style="{StaticResource HelperTextStyle}" />
                        <CheckBox Content="Show Bearish SMT" IsChecked="{Binding ShowBearishSmt}" />
                        <TextBlock Text="Displays high-break divergence events and their high-to-high lines."
                                   Style="{StaticResource HelperTextStyle}" />
                        <CheckBox Content="Sound alerts" IsChecked="{Binding SoundAlerts}" />
                        <TextBlock Text="Plays a local sound when a new visible SMT event appears."
                                   Style="{StaticResource HelperTextStyle}" />
                        <CheckBox Content="Desktop notifications" IsChecked="{Binding DesktopNotifications}" />
                        <TextBlock Text="Promotes the newest SMT event in the dashboard status area."
                                   Style="{StaticResource HelperTextStyle}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
